<odoo>
  <data>
    <!-- Definicion explicita de la vista de lista -->

    <record model="ir.ui.view" id="mi_modulo.list">
      <field name="name">mi_modulo lista</field>
      <field name="model">mi_modulo.mi_modulo</field>
      <field name="arch" type="xml">
        <tree>
          <field name="nombre"/>
          <field name="valor"/>
          <field name="porcentaje_valor"/>
        </tree>
      </field>
    </record>


    <!-- Acciones para abrir vistas de modelos -->

    <record model="ir.actions.act_window" id="mi_modulo.action_window">
      <field name="name">Registros de Mi Modulo</field>
      <field name="res_model">mi_modulo.mi_modulo</field>
      <field name="view_mode">tree,form</field>
    </record>


    <!-- Accion de servidor asociada a la accion anterior -->

    <record model="ir.actions.server" id="mi_modulo.action_server">
      <field name="name">Abrir lista por servidor</field>
      <field name="model_id" ref="model_mi_modulo_mi_modulo"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>


  
    <menuitem name="Mi Modulo Interno" id="mi_modulo.menu_root" groups="base.group_no_one"/>

    <!-- Categorias de menu -->

    <menuitem name="Gestion basica" id="mi_modulo.menu_1" parent="mi_modulo.menu_root" groups="base.group_no_one"/>
    <menuitem name="Acciones de servidor" id="mi_modulo.menu_2" parent="mi_modulo.menu_root" groups="base.group_no_one"/>

    <!-- Acciones -->

    <menuitem name="Lista" id="mi_modulo.menu_1_list" parent="mi_modulo.menu_1" groups="base.group_no_one"
              action="mi_modulo.action_window"/>
    <menuitem name="Servidor a lista" id="mi_modulo" parent="mi_modulo.menu_2" groups="base.group_no_one"
              action="mi_modulo.action_server"/>

  </data>
</odoo>
