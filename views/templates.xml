<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- TREE (LIST) VIEW USUARIO -->
    <!-- ========================= -->
    <record id="view_usuario_tree" model="ir.ui.view">
        <field name="name">mi_modulo.usuario.tree</field>
        <field name="model">mi_modulo.usuario</field>
        <field name="arch" type="xml">
            <tree string="Usuarios">
                <field name="name"/>
                <field name="age"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- FORM VIEW USUARIO -->
    <!-- ========================= -->
    <record id="view_usuario_form" model="ir.ui.view">
        <field name="name">mi_modulo.usuario.form</field>
        <field name="model">mi_modulo.usuario</field>
        <field name="arch" type="xml">
            <form string="Usuario">
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="description"/>
                    </group>

                    <notebook>
                        <page string="Teléfonos">
                            <field name="telefono">
                                <tree editable="bottom">
                                    <field name="numero"/>
                                    <field name="tipo"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- ACTION -->
    <!-- ========================= -->
    <record id="action_usuario" model="ir.actions.act_window">
        <field name="name">Usuarios</field>
        <field name="res_model">mi_modulo.usuario</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ========================= -->
    <!-- MENU -->
    <!-- ========================= -->
    <menuitem id="menu_mi_modulo_root"
              name="Mi Módulo"/>

    <menuitem id="menu_usuario"
              name="Usuarios"
              parent="menu_mi_modulo_root"
              action="action_usuario"/>

</odoo>
